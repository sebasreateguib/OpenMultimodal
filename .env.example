# Google Gemini (VLM + text embeddings) — also used as GOOGLE_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Groq for fast text LLMs (Llama, etc.)
GROQ_API_KEY=

# LlamaCloud / LlamaParse
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# Qdrant (local default; set API key for Qdrant Cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Optional overrides
# DEFAULT_LLM_PROVIDER=gemini
# GEMINI_MODEL=gemini-3.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# TEXT_EMBEDDING_MODEL=gemini-embedding-2
# SIMILARITY_TOP_K=5
# IMAGE_SIMILARITY_TOP_K=3
